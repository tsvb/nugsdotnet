@using System.Globalization
@inject PlayerService Player
@inject IJSRuntime JS
@implements IDisposable

@*
    The custom transport bar. Owns the in-theme play/pause, an accessible seek
    slider, and volume — replacing the browser-native <audio controls> chrome.
    Reads all runtime state from PlayerService.Playback (fed by JS via the
    layout) so it stays a single source of truth. Isolated into its own
    component so the ~5x/sec playback ticks re-render only the transport, not
    the whole shell.
*@

<div class="transport">
    <div class="now">
        @if (Player.Current is not null)
        {
            <div class="title">
                <span class="qpos">@(Player.Index + 1)/@Player.Queue.Count</span>
                @Player.Current.Title
            </div>
            <div class="meta">
                @Player.Current.Artist@(string.IsNullOrEmpty(Player.Current.Show) ? null : $" · {Player.Current.Show}")
            </div>
        }
        else
        {
            <div class="meta dim">Nothing playing. Press / to search.</div>
        }
    </div>

    <div class="controls">
        <button class="ghost" aria-label="Previous track" title="Previous (p)"
                disabled="@(!Player.HasPrevious)" @onclick="() => Player.Previous()">◀◀</button>
        <button class="ghost play" aria-label="@(Playing ? "Pause" : "Play")" title="Play / pause (space)"
                disabled="@(Player.Current is null)" @onclick="TogglePlay">@(Playing ? "❚❚" : "▶")</button>
        <button class="ghost" aria-label="Next track" title="Next (n)"
                disabled="@(!Player.HasNext)" @onclick="() => Player.Next()">▶▶</button>
    </div>

    <div class="seek">
        <span class="t-time">@Fmt(Position)</span>
        <input type="range" class="seek-range" aria-label="Seek position"
               min="0" max="@MaxSeconds" step="1" disabled="@(Duration <= 0)"
               style="--fill:@SeekFill"
               value="@SeekValue.ToString("0", CultureInfo.InvariantCulture)"
               @onpointerdown="() => _scrubbing = true"
               @oninput="OnSeekInput"
               @onchange="OnSeekChange" />
        <span class="t-time dim">@(Duration > 0 ? "-" + Fmt(Duration - Position) : "--:--")</span>
    </div>

    <div class="vol">
        <span class="vol-label" aria-hidden="true">VOL</span>
        <input type="range" class="vol-range" aria-label="Volume"
               min="0" max="1" step="0.01" style="--fill:@VolFill"
               value="@Volume.ToString("0.##", CultureInfo.InvariantCulture)"
               @oninput="OnVolInput" />
    </div>
</div>

@code {
    private bool _scrubbing;
    private double _scrubValue;

    private PlaybackStatus? S => Player.Playback;
    private double Position => S?.CurrentTime ?? 0;
    private double Duration => S is { Duration: > 0 } ? S.Duration : 0;
    private int MaxSeconds => Duration > 0 ? (int)Duration : 0;
    private double Volume => S?.Volume ?? 1;
    private bool Playing => Player.IsPlaying;
    // While the user drags, hold the thumb at the dragged value so the ~5x/sec
    // ticks don't yank it back; otherwise follow the live position.
    private double SeekValue => _scrubbing ? _scrubValue : Position;
    private string SeekFill => Pct(Duration > 0 ? Math.Clamp(SeekValue / Duration, 0, 1) : 0);
    private string VolFill => Pct(Math.Clamp(Volume, 0, 1));
    private static string Pct(double f) => (f * 100).ToString("0.##", CultureInfo.InvariantCulture) + "%";

    protected override void OnInitialized()
    {
        Player.StateChanged += Render;
        Player.PlaybackChanged += Render;
    }

    private void Render() => InvokeAsync(StateHasChanged);

    private async Task TogglePlay() => await JS.InvokeVoidAsync("audioInterop.toggle");

    private void OnSeekInput(ChangeEventArgs e)
    {
        _scrubbing = true;
        if (double.TryParse(e.Value?.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out var v))
            _scrubValue = v;
    }

    private async Task OnSeekChange(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out var v))
            await JS.InvokeVoidAsync("audioInterop.setCurrentTime", v);
        _scrubbing = false;
    }

    private async Task OnVolInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out var v))
            await JS.InvokeVoidAsync("audioInterop.setVolume", v);
    }

    private static string Fmt(double seconds)
    {
        if (double.IsNaN(seconds) || double.IsInfinity(seconds) || seconds < 0) seconds = 0;
        var ts = TimeSpan.FromSeconds(seconds);
        return ((int)ts.TotalMinutes).ToString(CultureInfo.InvariantCulture) + ":" + ts.Seconds.ToString("00");
    }

    public void Dispose()
    {
        Player.StateChanged -= Render;
        Player.PlaybackChanged -= Render;
    }
}
