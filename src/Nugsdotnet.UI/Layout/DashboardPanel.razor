@inject PlayerService Player
@inject DashboardState Dashboard
@inject INugsGateway Api
@inject IJSRuntime JS

@*
    Right-hand "nerdy" dashboard. Read-only. Four collapsible sections whose
    open/closed state is owned by DashboardState (persisted to localStorage).
    Live audio telemetry is pushed from audio-interop.js via OnAudioStats;
    stream quality is fetched from /api/stream-info on each track change.

    The <details> sections use @onclick:preventDefault on the summary so the
    browser's native toggle never fires — DashboardState is the single source
    of truth for the open attribute, keeping it in sync with localStorage.
*@

<aside class="dashboard-panel">
    @{
        var cur = Player.Current;
    }

    <details class="panel-section" open="@Dashboard.SectionOpen[0]">
        <summary @onclick:preventDefault @onclick="() => Dashboard.ToggleSection(0)">Now Playing</summary>
        <div class="panel-section-body">
            @if (cur is not null)
            {
                <div class="np-title">@cur.Title</div>
                <div class="np-meta dim">
                    @cur.Artist@(string.IsNullOrEmpty(cur.Show) ? null : $" · {cur.Show}")
                </div>
                <div class="progress-bar-track" aria-hidden="true"
                     title="Click to seek" @onclick="SeekClick">
                    <div class="progress-bar-fill" style="width:@Pct(ProgressFraction)"></div>
                </div>
                <div class="time-row">
                    <span>@Fmt(S?.CurrentTime ?? 0)</span>
                    <span>@(StreamDuration > 0 ? "-" + Fmt(StreamDuration - (S?.CurrentTime ?? 0)) : "--:--")</span>
                </div>
            }
            else
            {
                <div class="dim">Nothing playing.</div>
            }
        </div>
    </details>

    <details class="panel-section" open="@Dashboard.SectionOpen[1]">
        <summary @onclick:preventDefault @onclick="() => Dashboard.ToggleSection(1)">Up Next</summary>
        <div class="panel-section-body">
            @if (Player.Queue.Count > 0)
            {
                <ol class="queue-list">
                    @for (var i = 0; i < Player.Queue.Count; i++)
                    {
                        var idx = i;
                        var t = Player.Queue[idx];
                        <li class="queue-item @(idx == Player.Index ? "active" : null)">
                            <button class="queue-jump" title="@($"Play: {t.Title}")"
                                    @onclick="() => Player.JumpTo(idx)">
                                <span class="q-idx">@(idx + 1).</span><span class="q-title">@t.Title</span>
                            </button>
                            <button class="queue-remove" aria-label="Remove from queue" title="Remove"
                                    @onclick="() => Player.RemoveAt(idx)">×</button>
                        </li>
                    }
                </ol>
                <button class="ghost queue-clear" @onclick="() => Player.Clear()">Clear queue</button>
            }
            else
            {
                <div class="dim">Queue is empty.</div>
            }
        </div>
    </details>

    <details class="panel-section" open="@Dashboard.SectionOpen[2]">
        <summary @onclick:preventDefault @onclick="() => Dashboard.ToggleSection(2)">Quality &amp; Format</summary>
        <div class="panel-section-body">
            @if (_streamInfo is not null)
            {
                <div class="spec-grid">
                    <span class="spec-label">Format</span>
                    <span class="spec-value">@_streamInfo.FormatLabel</span>

                    @if (_streamInfo.SampleRate is int sr)
                    {
                        <span class="spec-label">Sample rate</span>
                        <span class="spec-value">@FmtKhz(sr)</span>
                    }
                    @if (_streamInfo.BitDepth is int bd)
                    {
                        <span class="spec-label">Bit depth</span>
                        <span class="spec-value">@bd-bit</span>
                    }
                    @if (_streamInfo.Channels is int ch)
                    {
                        <span class="spec-label">Channels</span>
                        <span class="spec-value">@ChannelLabel(ch)</span>
                    }
                    @if (_streamInfo.AvgBitrateKbps is double br)
                    {
                        <span class="spec-label">Avg bitrate</span>
                        <span class="spec-value">@br.ToString("0") kbps</span>
                    }
                    @if (_streamInfo.FileSizeBytes is long fs)
                    {
                        <span class="spec-label">File size</span>
                        <span class="spec-value">@FmtBytes(fs)</span>
                    }
                    <span class="spec-label">Source</span>
                    <span class="spec-value">@_streamInfo.FormatName · platform @_streamInfo.PlatformId</span>

                    @if (!_streamInfo.Playable)
                    {
                        <span class="spec-label">Note</span>
                        <span class="spec-value">HLS — not playable in-browser</span>
                    }
                </div>
            }
            else if (cur is not null)
            {
                <div class="dim">Resolving…</div>
            }
            else
            {
                <div class="dim">No stream.</div>
            }
        </div>
    </details>

    <details class="panel-section" open="@Dashboard.SectionOpen[3]">
        <summary @onclick:preventDefault @onclick="() => Dashboard.ToggleSection(3)">Telemetry</summary>
        <div class="panel-section-body">
            @if (S is not null)
            {
                <div class="telem-grid">
                    <span class="telem-label">Buffered ahead</span>
                    <span class="telem-value">@S.BufferedAhead.ToString("0.0")s</span>

                    <span class="telem-label">Network</span>
                    <span class="telem-value">@NetworkLabel(S.NetworkState)</span>

                    <span class="telem-label">Ready</span>
                    <span class="telem-value">@ReadyLabel(S.ReadyState)</span>

                    <span class="telem-label">State</span>
                    <span class="telem-value">@(S.Paused ? "paused" : "playing")</span>

                    <span class="telem-label">Volume</span>
                    <span class="telem-value">@((S.Volume * 100).ToString("0"))%</span>

                    <span class="telem-label">Rate</span>
                    <span class="telem-value">@S.PlaybackRate.ToString("0.0")×</span>

                    <span class="telem-label">Effective bitrate</span>
                    <span class="telem-value">@EffectiveBitrate</span>

                    <span class="telem-label">Downloaded</span>
                    <span class="telem-value">@DownloadedLabel</span>

                    <span class="telem-label">Rebuffers</span>
                    <span class="telem-value">@S.RebufferCount</span>
                </div>
            }
            else
            {
                <div class="dim">No telemetry yet.</div>
            }
        </div>
    </details>
</aside>
