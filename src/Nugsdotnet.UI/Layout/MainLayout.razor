@inherits LayoutComponentBase
@inject INugsGateway Api
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject PlayerService Player
@inject CatalogCache Catalog
@inject DashboardState Dashboard
@inject IMediaUrls MediaUrls
@implements IAsyncDisposable

@*
    Persistent app shell. Lives across all routes — owns the <audio> element,
    JS interop, search input, and login gate. The routed page renders into
    @Body in the middle.

    PlayerService holds queue state in DI so audio survives navigation.
    When PlayerService raises TrackChangeRequested, we call setSrcAndPlay
    on the audio element here.
*@

@if (_session is null)
{
    <div class="loading">Loading…</div>
}
else if (!_session.LoggedIn)
{
    <Login OnLoggedIn="HandleLoggedIn" />
}
else
{
    <div class="app">
        <header class="topbar">
            <a class="brand" href="/" @onclick="GoHome" @onclick:preventDefault>nugsdotnet</a>
            <form @onsubmit="DoSearch" @onsubmit:preventDefault>
                <input @ref="_searchInput"
                       class="search"
                       placeholder="Search artists, shows, songs…  (press /)"
                       @bind="_searchInputValue"
                       @bind:event="oninput" />
            </form>
            <div class="status">
                <span class="plan">@(_session.Plan ?? "—")</span>
                <button class="ghost panel-toggle @(Dashboard.PanelOpen ? "active" : null)"
                        aria-label="Toggle dashboard" aria-pressed="@Dashboard.PanelOpen"
                        title="Toggle dashboard (d)"
                        @onclick="Dashboard.TogglePanel">▦</button>
                <button class="ghost" @onclick="HandleSignOut">sign out</button>
            </div>
        </header>

        <div class="content-row @(Dashboard.PanelOpen ? "panel-open" : null)">
            <main class="main">
                <div class="main-inner">
                    @Body
                </div>
            </main>
            <DashboardPanel />
        </div>

        <footer class="player">
            <Transport />
            @* Hidden — the custom Transport above is the visible/accessible control surface.
               Two elements ping-pong for gapless playback; identity is owned by the JS
               state machine (audio-interop.js), the class is only for the CSS hide rule. *@
            <audio @ref="_audioA" class="audio" aria-hidden="true"></audio>
            <audio @ref="_audioB" class="audio" aria-hidden="true"></audio>
        </footer>

        @if (_toast is not null)
        {
            <div class="toast">@_toast</div>
        }
    </div>
}

@code {
    private SessionInfo? _session;
    private string _searchInputValue = "";
    private ElementReference _searchInput;
    private ElementReference _audioA;
    private ElementReference _audioB;
    private string? _preloadedTrackId;
    private DotNetObjectReference<MainLayout>? _selfRef;
    private bool _keysBound;
    private string? _toast;
    private int _toastGen;

    protected override async Task OnInitializedAsync()
    {
        Player.StateChanged += OnStateChanged;
        Player.TrackChangeRequested += OnTrackChangeRequested;
        Player.QueueChanged += OnQueueChanged;
        Dashboard.StateChanged += OnStateChanged;
        try { _session = await Api.GetSessionAsync(); }
        catch { _session = new SessionInfo(false); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_keysBound && _session is { LoggedIn: true })
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("audioInterop.init", _audioA, _audioB, _selfRef);
            await JS.InvokeVoidAsync("audioInterop.bindGlobalKeys", _selfRef);
            await Dashboard.RestoreAsync(JS);
            _keysBound = true;
        }
    }

    [JSInvokable]
    public async Task OnGlobalKey(string key)
    {
        switch (key)
        {
            case "/": await _searchInput.FocusAsync(); break;
            case " ": await JS.InvokeVoidAsync("audioInterop.toggle"); break;
            case "n": Player.Next(); break;
            case "p": Player.Previous(); break;
            case "d": Dashboard.TogglePanel(); break;
        }
    }

    /// <summary>Pushed from audio-interop.js — fan into the central PlayerService.</summary>
    [JSInvokable]
    public Task OnAudioStats(PlaybackStatus status)
    {
        Player.SetPlayback(status);
        return Task.CompletedTask;
    }

    /// <summary>The active &lt;audio&gt; element finished — advance the queue.
    /// (The Blazor @onended binding was replaced by a JS listener so it follows
    /// whichever element is currently audible.)</summary>
    [JSInvokable]
    public Task OnTrackEnded()
    {
        Player.HandleEnded();
        return Task.CompletedTask;
    }

    /// <summary>
    /// The &lt;audio&gt; element raised `error` (HLS 415 / no-stream 404 / network).
    /// Surface it and skip to the next track rather than stalling silently on a
    /// false "now playing".
    /// </summary>
    [JSInvokable]
    public Task OnAudioError()
    {
        if (Player.Current is null) return Task.CompletedTask;
        if (Player.HasNext)
        {
            _ = FlashToast("Can’t play that track — skipping");
            Player.Next();
        }
        else
        {
            _ = FlashToast("Can’t play that track");
        }
        return Task.CompletedTask;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    /// <summary>
    /// Show a brief confirmation when tracks are enqueued without replacing the
    /// queue. The generation counter ensures rapid successive adds don't let an
    /// earlier timer clear a later toast.
    /// </summary>
    private void OnQueueChanged(QueueOp op) => _ = FlashToast(op switch
    {
        QueueOp.Enqueued => "Added to queue",
        QueueOp.PlayingNext => "Playing next",
        _ => "",
    });

    /// <summary>
    /// Briefly show a transient message. The generation counter ensures rapid
    /// successive toasts don't let an earlier timer clear a later one.
    /// </summary>
    private async Task FlashToast(string message)
    {
        if (string.IsNullOrEmpty(message)) return;
        _toast = message;
        var gen = ++_toastGen;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(2200);
        if (gen == _toastGen)
        {
            _toast = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// PlayerService raised a track change. Do the active-element op for the
    /// kind, then re-sync preload — in that order, so the swap settles before we
    /// re-point the (now) idle element (see spec §5). Sync handler that schedules
    /// the async work; async-void would silently swallow exceptions.
    /// </summary>
    private void OnTrackChangeRequested(TrackChangeKind kind) => _ = HandleTrackChangeAsync(kind);

    private async Task HandleTrackChangeAsync(TrackChangeKind kind)
    {
        try
        {
            switch (kind)
            {
                case TrackChangeKind.Fresh:
                    if (Player.Current is null)
                        await JS.InvokeVoidAsync("audioInterop.stop");
                    else
                        await JS.InvokeVoidAsync("audioInterop.playTrack", MediaUrls.PlayUrl(Player.Current.TrackId));
                    break;

                case TrackChangeKind.Advance:
                    var swapped = await JS.InvokeAsync<bool>("audioInterop.advanceToPreloaded");
                    if (!swapped && Player.Current is not null)
                        await JS.InvokeVoidAsync("audioInterop.playTrack", MediaUrls.PlayUrl(Player.Current.TrackId));
                    _preloadedTrackId = null;   // the swap consumed the preload
                    break;

                case TrackChangeKind.PreloadOnly:
                    break;                      // no active-element op
            }
            await SyncPreloadAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"playback failed: {ex.Message}");
        }
    }

    /// <summary>Point the idle element at the current NextTrackId, but only when
    /// it differs from what's already preloaded (preloadNext is idempotent).</summary>
    private async Task SyncPreloadAsync()
    {
        var next = Player.NextTrackId;
        if (next == _preloadedTrackId) return;
        _preloadedTrackId = next;
        await JS.InvokeVoidAsync(
            "audioInterop.preloadNext",
            next is null ? null : MediaUrls.PlayUrl(next));
    }

    private async Task HandleLoggedIn()
    {
        _session = await Api.GetSessionAsync();
    }

    private async Task HandleSignOut()
    {
        await Api.LogoutAsync();
        _session = new SessionInfo(false);
        Player.Clear();
        Catalog.Clear();
        Nav.NavigateTo("/");
    }

    private void DoSearch()
    {
        var q = _searchInputValue.Trim();
        if (string.IsNullOrEmpty(q)) return;
        Nav.NavigateTo($"/search?q={Uri.EscapeDataString(q)}");
    }

    private void GoHome() => Nav.NavigateTo("/");

    public async ValueTask DisposeAsync()
    {
        Player.StateChanged -= OnStateChanged;
        Player.TrackChangeRequested -= OnTrackChangeRequested;
        Player.QueueChanged -= OnQueueChanged;
        Dashboard.StateChanged -= OnStateChanged;
        try { await JS.InvokeVoidAsync("audioInterop.dispose"); } catch { /* circuit gone */ }
        _selfRef?.Dispose();
    }
}
