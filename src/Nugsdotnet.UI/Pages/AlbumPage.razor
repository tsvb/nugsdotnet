@page "/album/{Id}"
@inject INugsGateway Api
@inject PlayerService Player
@inject NavigationManager Nav

@if (_error is not null)
{
    <div class="error">@_error</div>
}
<AlbumDetail Data="_data" Debug="false"
             OnPlay="Play" OnPlayNext="PlayNext" OnEnqueue="Enqueue"
             OnOpenArtist="OpenArtist" />

@code {
    [Parameter] public string Id { get; set; } = "";

    private System.Text.Json.Nodes.JsonNode? _data;
    private string? _error;
    private string? _lastId;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(Id) || Id == _lastId) return;
        _lastId = Id;
        _data = null;
        _error = null;
        try { _data = await Api.GetAlbumAsync(Id); }
        catch (Exception ex) { _error = ex.Message; }
    }

    private void Play(PlayRequest req) => Player.Play(req);
    private void PlayNext(IReadOnlyList<NowPlaying> tracks) => Player.PlayNext(tracks);
    private void Enqueue(IReadOnlyList<NowPlaying> tracks) => Player.Enqueue(tracks);
    private void OpenArtist(string id) => Nav.NavigateTo($"/artist/{id}");
}
