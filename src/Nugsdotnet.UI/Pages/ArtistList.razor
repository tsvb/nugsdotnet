@inject INugsGateway Api

@*
    Filterable list of every artist in the nugs catalog. Used as the
    landing view after login. Home owns the parsed list and re-passes
    it to us so navigating away and back doesn't refetch.
*@

@if (Artists is null)
{
    <div class="loading">Loading artists…</div>
}
else if (Debug)
{
    <pre class="json">@(RawForDebug?.ToJsonString(_pretty) ?? "(no raw data)")</pre>
}
else
{
    <div class="artistlist-header">
        <input @ref="_filterInput"
               class="search"
               placeholder="@($"Filter {Artists.Count:N0} artists…")"
               @bind="_filter"
               @bind:event="oninput" />
    </div>

    @if (Visible.Count == 0)
    {
        <p class="dim" style="margin-top: 16px;">No matches.</p>
    }
    else
    {
        <ul class="list" style="margin-top: 12px;">
            @foreach (var a in Visible)
            {
                <li>
                    <button class="link" @onclick="() => OnOpenArtist.InvokeAsync(a.Id)">
                        @a.Name
                    </button>
                </li>
            }
        </ul>
    }
}

@code {
    [Parameter] public List<Artist>? Artists { get; set; }
    [Parameter] public bool Debug { get; set; }
    [Parameter] public System.Text.Json.Nodes.JsonNode? RawForDebug { get; set; }
    [Parameter] public EventCallback<string> OnOpenArtist { get; set; }

    private string _filter = "";
    private ElementReference _filterInput;

    private static readonly System.Text.Json.JsonSerializerOptions _pretty
        = new() { WriteIndented = true };

    private List<Artist> Visible
    {
        get
        {
            if (Artists is null) return new();
            if (string.IsNullOrEmpty(_filter)) return Artists;
            return Artists
                .Where(a => a.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    public sealed record Artist(string Id, string Name);
}
