@page "/"
@inject CatalogCache Catalog
@inject NavigationManager Nav

@*
    Landing page — the full filterable artist list. Cached in CatalogCache
    so navigating away and back doesn't refetch.
*@

<ArtistList Artists="_artists"
            RawForDebug="_artistsRaw"
            Debug="false"
            OnOpenArtist="OpenArtist" />

@code {
    private List<ArtistList.Artist>? _artists;
    private System.Text.Json.Nodes.JsonNode? _artistsRaw;

    protected override async Task OnInitializedAsync()
    {
        if (Catalog.HasArtists)
        {
            _artists = Catalog.AllArtists!.Select(a => new ArtistList.Artist(a.Id, a.Name)).ToList();
            _artistsRaw = Catalog.AllArtistsRaw;
            return;
        }
        var fetched = await Catalog.GetAllArtistsAsync();
        _artists = fetched.Select(a => new ArtistList.Artist(a.Id, a.Name)).ToList();
        _artistsRaw = Catalog.AllArtistsRaw;
    }

    private void OpenArtist(string id) => Nav.NavigateTo($"/artist/{id}");
}
