<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Nugsdotnet.Native.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/Brand.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Override the Fluent accent (amber) for AccentButton + slider fills.
                 These brushes are consumed via ThemeResource, so the override must
                 live in ThemeDictionaries — a root-level override is ignored and the
                 system accent (teal here) leaks through. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="SystemAccentColor">#FFFFB22E</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#FFFFB22E" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#FFF0A828" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#FFD8951F" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FF1A1206" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#FF1A1206" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="SystemAccentColor">#FFFFB22E</Color>
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#FFFFB22E" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#FFF0A828" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#FFD8951F" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FF1A1206" />
                    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#FF1A1206" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
