<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Nugsdotnet.Native.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/Brand.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ResourceDictionary.ThemeDictionaries>
                <!-- Both keys filled so the override holds regardless of resolved theme.
                     The Fluent *accent* itself is hard-coded in WinUI 3 (#6394) — primary
                     buttons use the custom PlayButtonStyle instead. These per-control Slider
                     brushes are ordinary theme resources and DO override, so the seek/volume
                     fills + thumbs read amber. -->
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="SliderTrackValueFill" Color="#FFFFB22E" />
                    <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="#FFFF7A1A" />
                    <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="#FFFF7A1A" />
                    <SolidColorBrush x:Key="SliderThumbBackground" Color="#FFFFB22E" />
                    <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#FFFF7A1A" />
                    <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#FFFF7A1A" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SliderTrackValueFill" Color="#FFFFB22E" />
                    <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="#FFFF7A1A" />
                    <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="#FFFF7A1A" />
                    <SolidColorBrush x:Key="SliderThumbBackground" Color="#FFFFB22E" />
                    <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#FFFF7A1A" />
                    <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#FFFF7A1A" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
