<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Nugsdotnet.Native.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Nugsdotnet.Native.Views">

    <Grid>
        <!-- Logged-out -->
        <views:LoginView x:Name="LoginPanel" Visibility="Collapsed" />

        <!-- Logged-in shell: topbar / content / transport -->
        <Grid x:Name="MainPanel" Visibility="Collapsed" RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0" Padding="16,10" ColumnDefinitions="*,Auto"
                  Background="{ThemeResource LayerFillColorDefaultBrush}">
                <TextBlock Grid.Column="0" Text="nugsdotnet" FontSize="18"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="sign out" Click="OnSignOut" />
            </Grid>

            <views:SearchView Grid.Row="1" />
            <views:TransportView Grid.Row="2" />
        </Grid>
    </Grid>
</Window>
