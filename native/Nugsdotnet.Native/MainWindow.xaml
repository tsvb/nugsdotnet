<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Nugsdotnet.Native.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Nugsdotnet.Native.Views">

    <Grid>
        <!-- Logged-out -->
        <views:LoginView x:Name="LoginPanel" Visibility="Collapsed" />

        <!-- Logged-in shell: topbar / page frame / transport -->
        <Grid x:Name="MainPanel" Visibility="Collapsed" RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="8"
                  ColumnDefinitions="Auto,Auto,*,Auto"
                  Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Button Grid.Column="0" Content="◀" Click="OnBack" ToolTipService.ToolTip="Back" />
                <Button Grid.Column="1" Content="nugsdotnet" Click="OnHome"
                        Background="Transparent" BorderThickness="0" FontWeight="SemiBold" FontSize="16" />
                <AutoSuggestBox Grid.Column="2" x:Name="SearchBox" QueryIcon="Find"
                                PlaceholderText="Search artists, shows, songs…"
                                QuerySubmitted="OnSearchSubmitted" />
                <Button Grid.Column="3" Content="sign out" Click="OnSignOut" />
            </Grid>

            <Frame Grid.Row="1" x:Name="ContentFrame" />
            <views:TransportView Grid.Row="2" />
        </Grid>
    </Grid>
</Window>
