<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nugsdotnet.Native.Views.TransportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="12,8" ColumnSpacing="12"
          ColumnDefinitions="Auto,*,Auto,Auto"
          Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Button x:Name="PlayPauseButton" Grid.Column="0" Content="▶" Width="44" Click="OnPlayPause" />
        <Slider x:Name="PositionSlider" Grid.Column="1" Minimum="0" Maximum="1"
                StepFrequency="0.1" VerticalAlignment="Center"
                PointerPressed="OnSeekStart" PointerReleased="OnSeekEnd" />
        <TextBlock x:Name="TimeText" Grid.Column="2" VerticalAlignment="Center" Text="0:00 / 0:00" />
        <Slider x:Name="VolumeSlider" Grid.Column="3" Minimum="0" Maximum="100" Value="100"
                Width="100" VerticalAlignment="Center" ValueChanged="OnVolumeChanged" />
    </Grid>
</UserControl>
