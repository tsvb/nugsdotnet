<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nugsdotnet.Native.Views.TransportView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="12,8" ColumnSpacing="10"
          ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto"
          Background="{ThemeResource LayerFillColorDefaultBrush}">
        <Button x:Name="PrevButton" Grid.Column="0" Content="⏮" Click="OnPrev" ToolTipService.ToolTip="Previous" />
        <Button x:Name="PlayPauseButton" Grid.Column="1" Content="▶" Width="44" Click="OnPlayPause" />
        <Button x:Name="NextButton" Grid.Column="2" Content="⏭" Click="OnNext" ToolTipService.ToolTip="Next" />

        <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="2">
            <TextBlock x:Name="NowPlayingText" Text="" TextTrimming="CharacterEllipsis" />
            <Slider x:Name="PositionSlider" Minimum="0" Maximum="1" StepFrequency="0.1" Margin="0"
                    PointerPressed="OnSeekStart" PointerReleased="OnSeekEnd" />
        </StackPanel>

        <TextBlock x:Name="TimeText" Grid.Column="4" VerticalAlignment="Center" Text="0:00 / 0:00" />
        <Slider x:Name="VolumeSlider" Grid.Column="5" Minimum="0" Maximum="100" Value="100" Width="90"
                VerticalAlignment="Center" ValueChanged="OnVolumeChanged" />
    </Grid>
</UserControl>
