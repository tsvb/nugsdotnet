<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nugsdotnet.Native.Views.Pages.ArtistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Nugsdotnet.Native.Core">

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="14">
            <TextBlock Text="{Binding ArtistName}" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="{Binding Status}" Foreground="Gray" />

            <StackPanel x:Name="ReleasesSection" Spacing="4" Visibility="Collapsed">
                <TextBlock Text="Releases" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ListView ItemsSource="{Binding Releases}" SelectionMode="None"
                          IsItemClickEnabled="True" ItemClick="OnContainerClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:ContainerEntry">
                            <TextBlock Text="{x:Bind Title}" Padding="0,4" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel x:Name="ShowsSection" Spacing="4" Visibility="Collapsed">
                <TextBlock Text="Shows" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ListView ItemsSource="{Binding Shows}" SelectionMode="None"
                          IsItemClickEnabled="True" ItemClick="OnContainerClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:ContainerEntry">
                            <StackPanel Padding="0,4">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Subtitle}" Foreground="Gray" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
