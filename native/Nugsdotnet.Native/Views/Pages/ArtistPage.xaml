<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nugsdotnet.Native.Views.Pages.ArtistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Nugsdotnet.Native.Core"
    Background="{StaticResource BrandBg}">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="14">
            <TextBlock Text="{Binding ArtistName}" FontFamily="{StaticResource BrandDisplayFont}"
                       FontWeight="ExtraBold" FontSize="30" CharacterSpacing="20"
                       Foreground="{StaticResource BrandText}" />
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource BrandDim}" />

            <StackPanel x:Name="ReleasesSection" Spacing="6" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="6" Height="6" CornerRadius="1" VerticalAlignment="Center"
                            Background="{StaticResource BrandAccent}" />
                    <TextBlock Text="RELEASES" FontFamily="{StaticResource BrandMonoFont}" FontSize="11"
                               CharacterSpacing="140" Foreground="{StaticResource BrandDim}" />
                </StackPanel>
                <ListView ItemsSource="{Binding Releases}" SelectionMode="None"
                          IsItemClickEnabled="True" ItemClick="OnContainerClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:ContainerEntry">
                            <TextBlock Text="{x:Bind Title}" Padding="0,4" Foreground="{StaticResource BrandText}"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel x:Name="ShowsSection" Spacing="6" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="6" Height="6" CornerRadius="1" VerticalAlignment="Center"
                            Background="{StaticResource BrandAccent}" />
                    <TextBlock Text="SHOWS" FontFamily="{StaticResource BrandMonoFont}" FontSize="11"
                               CharacterSpacing="140" Foreground="{StaticResource BrandDim}" />
                </StackPanel>
                <ListView ItemsSource="{Binding Shows}" SelectionMode="None"
                          IsItemClickEnabled="True" ItemClick="OnContainerClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:ContainerEntry">
                            <StackPanel Padding="0,4">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandText}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Subtitle}" FontSize="12"
                                           FontFamily="{StaticResource BrandMonoFont}" Foreground="{StaticResource BrandDim}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
