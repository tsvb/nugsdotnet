<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nugsdotnet.Native.Views.Pages.ArtistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Nugsdotnet.Native.Core"
    xmlns:vm="using:Nugsdotnet.Native.ViewModels"
    Background="{StaticResource BrandBg}">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="14">
            <TextBlock Text="{Binding ArtistName}" FontFamily="{StaticResource BrandDisplayFont}"
                       FontWeight="ExtraBold" FontSize="30" CharacterSpacing="20"
                       Foreground="{StaticResource BrandText}" />
            <ProgressRing x:Name="BusyRing" IsActive="True" Visibility="Collapsed"
                          Width="28" Height="28" HorizontalAlignment="Left"
                          Foreground="{StaticResource BrandAccent}" />
            <TextBlock Text="{Binding Status}" Foreground="{StaticResource BrandDim}" />

            <!-- ── RELEASES — art-card rail ────────────────────────────── -->
            <StackPanel x:Name="ReleasesSection" Spacing="10" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="6" Height="6" CornerRadius="1" VerticalAlignment="Center"
                            Background="{StaticResource BrandAccent}" />
                    <TextBlock Text="RELEASES" FontFamily="{StaticResource BrandMonoFont}" FontSize="11"
                               CharacterSpacing="140" Foreground="{StaticResource BrandDim}" />
                </StackPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled">
                    <ItemsControl ItemsSource="{Binding Releases}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShowCard">
                                <Button Style="{StaticResource CardButtonStyle}"
                                        Tag="{x:Bind}" Click="OnReleaseClick">
                                    <StackPanel Width="150" Spacing="6">
                                        <Border Width="150" Height="150" CornerRadius="4"
                                                Background="{StaticResource BrandSurface2}"
                                                BorderBrush="{StaticResource BrandBorder}" BorderThickness="1">
                                            <Image Source="{x:Bind Art, Mode=OneWay}" Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Text="{x:Bind Title}" Height="36"
                                                   FontFamily="{StaticResource BrandBodyFont}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource BrandText}"
                                                   TextWrapping="Wrap" MaxLines="2"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <!-- ── SHOWS — virtualized list (can run to hundreds) ──────── -->
            <StackPanel x:Name="ShowsSection" Spacing="6" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="6" Height="6" CornerRadius="1" VerticalAlignment="Center"
                            Background="{StaticResource BrandAccent}" />
                    <TextBlock x:Name="ShowsLabel" Text="SHOWS"
                               FontFamily="{StaticResource BrandMonoFont}" FontSize="11"
                               CharacterSpacing="140" Foreground="{StaticResource BrandDim}" />
                </StackPanel>
                <ListView ItemsSource="{Binding Shows}" SelectionMode="None"
                          IsItemClickEnabled="True" ItemClick="OnContainerClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:ContainerEntry">
                            <StackPanel Padding="0,6">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandText}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Subtitle}" FontSize="12"
                                           FontFamily="{StaticResource BrandMonoFont}" Foreground="{StaticResource BrandDim}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
