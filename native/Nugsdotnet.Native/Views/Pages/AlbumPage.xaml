<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nugsdotnet.Native.Views.Pages.AlbumPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Nugsdotnet.Native.Core"
    xmlns:vm="using:Nugsdotnet.Native.ViewModels"
    Background="{StaticResource BrandBg}">

    <Page.Resources>
        <CollectionViewSource x:Name="TracksSource" IsSourceGrouped="True" />
    </Page.Resources>

    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <!-- header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="18">
            <Border Grid.Column="0" Width="150" Height="150" CornerRadius="4"
                    BorderBrush="{StaticResource BrandBorder}" BorderThickness="1"
                    Background="{StaticResource BrandSurface2}">
                <Image Source="{Binding Cover}" Stretch="UniformToFill" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                <TextBlock Text="{Binding Title}" TextWrapping="Wrap"
                           FontFamily="{StaticResource BrandDisplayFont}" FontWeight="ExtraBold"
                           FontSize="30" Foreground="{StaticResource BrandText}" />
                <TextBlock Text="{Binding Subtitle}" FontSize="12"
                           FontFamily="{StaticResource BrandMonoFont}" Foreground="{StaticResource BrandDim}" />
                <TextBlock Text="{Binding Runtime}" FontSize="12"
                           FontFamily="{StaticResource BrandMonoFont}" Foreground="{StaticResource BrandAccent}" />
                <Button Content="▶  Play all" Click="OnPlayAll" Margin="0,8,0,0"
                        Style="{StaticResource PlayButtonStyle}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="{StaticResource BrandDim}" />

        <ListView Grid.Row="2" x:Name="TracksList" SelectionMode="None">
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="vm:TrackGroup">
                            <TextBlock Text="{x:Bind Label}" CharacterSpacing="140" FontSize="11"
                                       FontFamily="{StaticResource BrandMonoFont}"
                                       Foreground="{StaticResource BrandAccent}" Margin="0,16,0,4" />
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:TrackRow">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="4" Padding="0,2">
                        <TextBlock Grid.Column="0" Text="{x:Bind Display}" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrandText}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="{x:Bind RunTime}" VerticalAlignment="Center"
                                   FontFamily="{StaticResource BrandMonoFont}" FontSize="12"
                                   Foreground="{StaticResource BrandDim}" Margin="0,0,10,0" />
                        <Button Grid.Column="2" Content="▶" Tag="{x:Bind}" Click="OnPlayTrack"
                                Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Play from here" />
                        <Button Grid.Column="3" Content="↪" Tag="{x:Bind}" Click="OnPlayNextTrack"
                                Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Play next" />
                        <Button Grid.Column="4" Content="＋" Tag="{x:Bind}" Click="OnEnqueueTrack"
                                Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Add to queue" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
