<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nugsdotnet.Native.Views.Pages.AlbumPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Nugsdotnet.Native.Core">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="12">
        <!-- header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="16">
            <Image Grid.Column="0" Source="{Binding Cover}" Width="120" Height="120" Stretch="UniformToFill" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                <TextBlock Text="{Binding Title}" Style="{ThemeResource TitleTextBlockStyle}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Subtitle}" Foreground="Gray" />
                <TextBlock Text="{Binding Runtime}" Foreground="Gray" FontSize="12" />
                <Button Content="▶ Play all" Click="OnPlayAll" Margin="0,6,0,0"
                        Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="Gray" />

        <ListView Grid.Row="2" ItemsSource="{Binding Tracks}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:TrackRow">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="6" Padding="0,4">
                        <TextBlock Grid.Column="0" Text="{x:Bind Display}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1" Text="{x:Bind RunTime}" Foreground="Gray"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                        <Button Grid.Column="2" Content="▶" Tag="{x:Bind}" Click="OnPlayTrack"
                                ToolTipService.ToolTip="Play from here" />
                        <Button Grid.Column="3" Content="↪" Tag="{x:Bind}" Click="OnPlayNextTrack"
                                ToolTipService.ToolTip="Play next" />
                        <Button Grid.Column="4" Content="＋" Tag="{x:Bind}" Click="OnEnqueueTrack"
                                ToolTipService.ToolTip="Add to queue" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
