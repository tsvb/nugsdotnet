<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nugsdotnet.Native.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Nugsdotnet.Native.Core"
    Background="{StaticResource BrandBg}">

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
            <Border Width="6" Height="6" CornerRadius="1" VerticalAlignment="Center"
                    Background="{StaticResource BrandAccent}" />
            <TextBlock Text="ARTISTS" FontFamily="{StaticResource BrandMonoFont}" FontSize="11"
                       CharacterSpacing="140" Foreground="{StaticResource BrandDim}" />
        </StackPanel>
        <TextBox Grid.Row="1" PlaceholderText="Filter artists…" MaxWidth="360" HorizontalAlignment="Left"
                 Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        <TextBlock Grid.Row="2" Foreground="{StaticResource BrandDim}" Text="{Binding Status}" />
        <ListView Grid.Row="3" ItemsSource="{Binding Artists}" SelectionMode="None"
                  IsItemClickEnabled="True" ItemClick="OnArtistClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:ArtistEntry">
                    <TextBlock Text="{x:Bind Name}" Padding="0,6" Foreground="{StaticResource BrandText}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
