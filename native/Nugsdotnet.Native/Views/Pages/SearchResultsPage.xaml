<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nugsdotnet.Native.Views.Pages.SearchResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Nugsdotnet.Native.Core"
    Background="{StaticResource BrandBg}">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="14">
            <TextBlock Text="{Binding Heading}" FontFamily="{StaticResource BrandDisplayFont}"
                       FontWeight="ExtraBold" FontSize="22" Foreground="{StaticResource BrandText}" />
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ProgressRing x:Name="BusyRing" IsActive="True" Visibility="Collapsed"
                              Width="22" Height="22" Foreground="{StaticResource BrandAccent}" />
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                           Foreground="{StaticResource BrandDim}" />
            </StackPanel>

            <StackPanel x:Name="ArtistsSection" Spacing="6" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="6" Height="6" CornerRadius="1" VerticalAlignment="Center"
                            Background="{StaticResource BrandAccent}" />
                    <TextBlock Text="ARTISTS" FontFamily="{StaticResource BrandMonoFont}" FontSize="11"
                               CharacterSpacing="140" Foreground="{StaticResource BrandDim}" />
                </StackPanel>
                <ListView ItemsSource="{Binding Artists}" SelectionMode="None"
                          IsItemClickEnabled="True" ItemClick="OnArtistClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:ArtistEntry">
                            <TextBlock Text="{x:Bind Name}" Padding="0,4" Foreground="{StaticResource BrandText}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel x:Name="ContainersSection" Spacing="6" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border Width="6" Height="6" CornerRadius="1" VerticalAlignment="Center"
                            Background="{StaticResource BrandAccent}" />
                    <TextBlock Text="SHOWS &amp; RELEASES" FontFamily="{StaticResource BrandMonoFont}" FontSize="11"
                               CharacterSpacing="140" Foreground="{StaticResource BrandDim}" />
                </StackPanel>
                <ListView ItemsSource="{Binding Containers}" SelectionMode="None"
                          IsItemClickEnabled="True" ItemClick="OnContainerClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:ContainerEntry">
                            <StackPanel Padding="0,4">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandText}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Subtitle}" FontSize="12"
                                           FontFamily="{StaticResource BrandMonoFont}" Foreground="{StaticResource BrandDim}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
