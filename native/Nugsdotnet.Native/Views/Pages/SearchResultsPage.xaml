<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Nugsdotnet.Native.Views.Pages.SearchResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Nugsdotnet.Native.Core">

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="14">
            <TextBlock Text="{Binding Heading}" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <TextBlock Text="{Binding Status}" Foreground="Gray" />

            <StackPanel x:Name="ArtistsSection" Spacing="4" Visibility="Collapsed">
                <TextBlock Text="Artists" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ListView ItemsSource="{Binding Artists}" SelectionMode="None"
                          IsItemClickEnabled="True" ItemClick="OnArtistClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:ArtistEntry">
                            <TextBlock Text="{x:Bind Name}" Padding="0,4" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <StackPanel x:Name="ContainersSection" Spacing="4" Visibility="Collapsed">
                <TextBlock Text="Shows &amp; releases" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ListView ItemsSource="{Binding Containers}" SelectionMode="None"
                          IsItemClickEnabled="True" ItemClick="OnContainerClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="core:ContainerEntry">
                            <StackPanel Padding="0,4">
                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Subtitle}" Foreground="Gray" FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
