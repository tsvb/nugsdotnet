<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nugsdotnet.Native.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BrandBg}">
        <Border MaxWidth="400" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{StaticResource BrandSurface}" BorderBrush="{StaticResource BrandBorder}"
                BorderThickness="1" CornerRadius="8" Padding="28">
            <StackPanel Spacing="12">
                <TextBlock Text="NUGSDOTNET" FontFamily="{StaticResource BrandDisplayFont}"
                           FontWeight="ExtraBold" FontSize="32" CharacterSpacing="40"
                           Foreground="{StaticResource BrandText}" />
                <TextBlock Text="native Windows client" Margin="0,-6,0,8" FontSize="12"
                           FontFamily="{StaticResource BrandMonoFont}" Foreground="{StaticResource BrandDim}" />

                <CheckBox Content="Use credentials from environment (NUGS_EMAIL / NUGS_PASSWORD)"
                          IsChecked="{Binding UseEnv, Mode=TwoWay}" />

                <TextBox Header="Email" Text="{Binding Email, Mode=TwoWay}" PlaceholderText="you@example.com" />
                <PasswordBox x:Name="PasswordInput" Header="Password" PasswordChanged="OnPasswordChanged" />

                <Button x:Name="SignInButton" Content="Sign in" Click="OnSignIn"
                        Style="{StaticResource PlayButtonStyle}" HorizontalAlignment="Stretch" />

                <TextBlock Text="{Binding Error}" Foreground="#FFEF4444" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
