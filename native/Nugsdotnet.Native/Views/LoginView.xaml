<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nugsdotnet.Native.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="40" MaxWidth="400" HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="12">
            <TextBlock Text="nugsdotnet" FontSize="30" FontWeight="SemiBold" />
            <TextBlock Text="native Windows client" Foreground="Gray" Margin="0,-6,0,8" />

            <CheckBox Content="Use credentials from environment (NUGS_EMAIL / NUGS_PASSWORD)"
                      IsChecked="{Binding UseEnv, Mode=TwoWay}" />

            <TextBox Header="Email" Text="{Binding Email, Mode=TwoWay}"
                     PlaceholderText="you@example.com" />
            <PasswordBox x:Name="PasswordInput" Header="Password"
                         PasswordChanged="OnPasswordChanged" />

            <Button x:Name="SignInButton" Content="Sign in" Click="OnSignIn"
                    Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" />

            <TextBlock Text="{Binding Error}" Foreground="OrangeRed" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
