<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Nugsdotnet.Native.Views.SearchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Nugsdotnet.Native.Core">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="QueryBox" Grid.Column="0"
                     PlaceholderText="Search artists, shows, songs…"
                     Text="{Binding Query, Mode=TwoWay}"
                     KeyDown="OnQueryKeyDown" />
            <Button Grid.Column="1" Content="Search" Click="OnSearch" />
        </Grid>

        <TextBlock Grid.Row="1" Margin="0,8" Foreground="Gray" Text="{Binding Status}" />

        <ListView Grid.Row="2" ItemsSource="{Binding Results}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:TrackEntry">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" Padding="0,6">
                        <Button Grid.Column="0" Content="▶" Click="OnPlay" Tag="{x:Bind}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Foreground="Gray" FontSize="12" Text="{x:Bind Artist}" />
                                <TextBlock Foreground="Gray" FontSize="12" Text="{x:Bind Show}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
